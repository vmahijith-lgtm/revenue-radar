# ==============================================
# Root-level .gitignore for attribution_engine
# ==============================================

# Python
venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.so

# Environment
.env
.env.*

# dbt artifacts (inside attribution_project)
attribution_project/target/
attribution_project/dbt_packages/
attribution_project/logs/

# DuckDB binary files (regenerated by the pipeline)
*.duckdb
*.duckdb.wal

# Generated data files
generated_clicks.csv

# Logs
logs/
*.log

# macOS
.DS_Store
.AppleDouble
.LSOverride
