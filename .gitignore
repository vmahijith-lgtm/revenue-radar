# ================================================
# Attribution Engine — .gitignore
# ================================================

# Python
venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.so
.Python

# Environment / secrets (but allow example file)
.env
.env.*
!.env.example
*.secret


# dbt build artifacts (always regenerated)
attribution_project/target/
attribution_project/dbt_packages/
attribution_project/logs/

# DuckDB database files (regenerated by pipeline)
*.duckdb
*.duckdb.wal

# Generated / sample data (large files, not needed in repo)
generated_clicks.csv
*.csv.bak

# Logs
logs/
*.log

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# IDE
.vscode/
.idea/
*.swp
*.swo

# Streamlit
.streamlit/secrets.toml

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
